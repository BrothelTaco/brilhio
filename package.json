{
  "name": "brilhio",
  "private": true,
  "version": "0.1.0",
  "description": "Purpose-built monorepo foundation for an AI social media manager across web, mobile, API, worker, and marketing surfaces.",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"corepack pnpm dev:web\" \"corepack pnpm dev:marketing\" \"corepack pnpm dev:api\" \"corepack pnpm dev:worker\"",
    "dev:web": "corepack pnpm --filter @brilhio/web dev",
    "dev:marketing": "corepack pnpm --filter @brilhio/marketing dev",
    "dev:mobile": "corepack pnpm --filter @brilhio/mobile dev",
    "dev:api": "corepack pnpm --filter @brilhio/api dev",
    "dev:worker": "corepack pnpm --filter @brilhio/worker dev",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  }
}
