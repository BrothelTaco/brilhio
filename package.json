{
  "name": "brilhio",
  "private": true,
  "version": "0.1.0",
  "description": "Purpose-built monorepo foundation for an AI social media manager across web, mobile, API, worker, and marketing surfaces.",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:marketing\" \"pnpm dev:api\" \"pnpm dev:worker\"",
    "dev:web": "dotenv -e .env -- pnpm --filter @brilhio/web dev",
    "dev:marketing": "dotenv -e .env -- pnpm --filter @brilhio/marketing dev",
    "dev:mobile": "dotenv -e .env -- pnpm --filter @brilhio/mobile dev",
    "dev:api": "dotenv -e .env -- pnpm --filter @brilhio/api dev",
    "dev:worker": "dotenv -e .env -- pnpm --filter @brilhio/worker dev",
    "build": "dotenv -e .env -- pnpm -r build",
    "typecheck": "dotenv -e .env -- pnpm -r typecheck",
    "test": "dotenv -e .env -- pnpm --filter @brilhio/api test",
    "test:stripe:e2e": "dotenv -e .env -- pnpm --filter @brilhio/api test:stripe:e2e"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.8.3"
  }
}
