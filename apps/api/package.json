{
  "name": "@brilhio/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "corepack pnpm typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:stripe:e2e": "node --import tsx --test \"src/**/*.e2e.test.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@brilhio/backend": "workspace:*",
    "@brilhio/contracts": "workspace:*",
    "@brilhio/utils": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@supabase/supabase-js": "^2.50.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3"
  }
}
